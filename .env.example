# ---- Database (Neon) — per environment; real values in Vercel dashboard ----
# Pooled connection (the `-pooler` endpoint) — used by the app at runtime.
DATABASE_URL=
# Unpooled/direct connection — used only for drizzle-kit generate/migrate/studio.
DATABASE_URL_UNPOOLED=

# ---- Auth.js (NextAuth v5) ----
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- Vercel Blob ----
# Auto-injected by Vercel once a Blob store is connected — do not set
# manually except for local dev against a real store.
BLOB_READ_WRITE_TOKEN=

# ---- Sentry (observability) ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Build-time only (source map upload) — set as a CI/Vercel build secret.
SENTRY_AUTH_TOKEN=

# ---- Upstash Redis (rate-limiting groundwork — not used yet, no routes need it) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Anthropic (future — server-side concierge calls, not used this session) ----
ANTHROPIC_API_KEY=

# ---- WhatsApp Business API (future — not used this session) ----
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ---- Payments — PayPlus/Cardcom (future, always-human wiring, 🔒 never autonomous) ----
PAYPLUS_API_KEY=
CARDCOM_API_KEY=
